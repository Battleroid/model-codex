<UserControl x:Class="ModelCodex.App.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ModelCodex.App.ViewModels"
             xmlns:tiger="clr-namespace:Tiger;assembly=Tiger"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LibraryViewModel}"
             Background="{StaticResource Bg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*" MinWidth="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="440" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: packages / categories with counts -->
        <Border Grid.Column="0" Background="{StaticResource Inset2}" BorderBrush="{StaticResource Outline}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="PACKAGES" Style="{StaticResource k}" Margin="12,12,12,6"/>
                <ListBox Style="{StaticResource CategoryList}" ItemContainerStyle="{StaticResource CategoryItem}"
                         ItemsSource="{Binding Packages}" SelectedItem="{Binding SelectedPackage}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type tiger:PackageGroup}">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="{StaticResource Inset3}" Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ModelCount}" Foreground="{StaticResource TextFaint}"
                                               FontSize="10"/>
                                </Border>
                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Middle: model grid (Phase 2 renders isometric thumbnails here) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Outline}"
                    BorderThickness="0,0,0,1" Padding="12,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding ResultCountText}"
                               Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center"/>
                    <CheckBox DockPanel.Dock="Right" Content="Hide empty" IsChecked="{Binding HideEmpty}"
                              Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding SelectedPackage.Display, FallbackValue=''}" Foreground="{StaticResource TextC}"
                               FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Grid Grid.Row="1">
                <TextBlock Text="{Binding EmptyMessage}" Foreground="{StaticResource TextFaint}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="380" TextAlignment="Center"/>
                <ListBox x:Name="GridList" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding VisibleModels}" SelectedItem="{Binding SelectedTile}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         MouseDoubleClick="OnModelActivated">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <vwp:VirtualizingWrapPanel Orientation="Horizontal" SpacingMode="Uniform"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="b" Background="{StaticResource Panel}" BorderThickness="2"
                                                BorderBrush="{StaticResource Outline}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{StaticResource PanelHi}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="158" Height="178" Background="Transparent"
                                  MouseMove="OnTileHover" MouseLeave="OnTileHoverEnd"
                                  DataContextChanged="OnTileBound" Loaded="OnTileLoaded">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open in tab" Click="OnCtxOpen"/>
                                        <MenuItem Header="Export" Click="OnCtxExport"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource Inset}" Margin="0">
                                    <Image Source="{Binding Thumb}" Stretch="Uniform" Margin="4"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding TagId}" Foreground="{StaticResource TextDim}"
                                           HorizontalAlignment="Center" FontSize="10" Padding="0,4"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Splitter to resize the preview panel -->
        <GridSplitter Grid.Column="2" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{StaticResource Outline}" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

        <!-- Right: live 3D preview -->
        <Border Grid.Column="3" Background="{StaticResource Inset2}" BorderBrush="{StaticResource Outline}"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedModel.TagId, FallbackValue='—'}" Style="{StaticResource Display}" FontSize="22"/>
                        <TextBlock Text="{Binding SelectedModel.Category}" Foreground="{StaticResource Accent}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                        <CheckBox Content="Textured" IsChecked="{Binding Textured}" Foreground="{StaticResource TextDim}"
                                  FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ComboBox Width="120" ItemsSource="{Binding LightingStyles}" DisplayMemberPath="Name"
                                  SelectedValuePath="Style" SelectedValue="{Binding Lighting}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox Width="120" ItemsSource="{Binding MaterialViews}" DisplayMemberPath="Name"
                                  SelectedValuePath="View" SelectedValue="{Binding MaterialView}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox Width="120" ItemsSource="{Binding DetailLevels}" DisplayMemberPath="Name"
                                  SelectedValuePath="Detail" SelectedValue="{Binding Detail}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox Width="120" ItemsSource="{Binding Permutations}" DisplayMemberPath="Name"
                                  SelectedValuePath="Index" SelectedValue="{Binding SelectedPermutation}" FontSize="11" Margin="0,0,0,4"
                                  Visibility="{Binding HasPermutations, Converter={StaticResource BoolVis}}"/>
                        <Button Width="120" Height="24" Click="OnPickBg" HorizontalContentAlignment="Stretch" Padding="6,0">
                            <DockPanel LastChildFill="False">
                                <Border DockPanel.Dock="Left" Width="13" Height="13" BorderBrush="{StaticResource Outline2}"
                                        BorderThickness="1" VerticalAlignment="Center">
                                    <Border.Background><SolidColorBrush Color="{Binding PreviewBg}"/></Border.Background>
                                </Border>
                                <TextBlock Text="Background…" Margin="7,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="8,0,8,8" Background="{StaticResource Inset}">
                    <hx:Viewport3DX Camera="{Binding Camera}" EffectsManager="{Binding EffectsManager}"
                                    BackgroundColor="{Binding PreviewBg}" ShowCoordinateSystem="True"
                                    CoordinateSystemLabelForeground="#9b9ba3"
                                    FixedRotationPointEnabled="True" ZoomExtentsWhenLoaded="False"
                                    IsInertiaEnabled="True" CameraMode="Inspect">
                        <hx:AmbientLight3D Color="{Binding Lights.Ambient}"/>
                        <hx:DirectionalLight3D Color="{Binding Lights.Key}" Direction="{Binding Lights.KeyDir}"/>
                        <hx:DirectionalLight3D Color="{Binding Lights.Fill}" Direction="{Binding Lights.FillDir}"/>
                        <hx:DirectionalLight3D Color="{Binding Lights.Rim}" Direction="{Binding Lights.RimDir}"/>
                        <hx:ItemsModel3D ItemsSource="{Binding PreviewModels}"/>
                    </hx:Viewport3DX>
                </Border>

                <StackPanel Grid.Row="2" Margin="12,0,12,12">
                    <TextBlock Text="{Binding PreviewInfo}" Foreground="{StaticResource TextDim}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="CHANNELS  (click to preview)" Style="{StaticResource k}" Margin="0,0,0,4"
                               Visibility="{Binding Channels.Count, Converter={StaticResource CountVis}}"/>
                    <ListBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}"
                             MaxHeight="150" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="cb" Background="{StaticResource Inset}" Padding="6,3" Cursor="Hand">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="cb" Property="Background" Value="{StaticResource PanelHi}"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="cb" Property="Background" Value="#FF2E3A12"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Format}"
                                               Foreground="{StaticResource TextFaint}" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TagId}" Foreground="{StaticResource TextC}" FontSize="10" Width="78"/>
                                    <TextBlock Foreground="{StaticResource TextDim}" FontSize="9" VerticalAlignment="Center">
                                        <Run Text="{Binding Width, Mode=OneWay}"/><Run Text="×"/><Run Text="{Binding Height, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Open in tab" Click="OnOpenSelected" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="ModelCodex.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ModelCodex.App.ViewModels"
        Title="Model Codex" Height="860" Width="1320" MinHeight="640" MinWidth="1000"
        Background="{StaticResource Bg}" FontFamily="{StaticResource MonoFont}"
        TextElement.Foreground="{StaticResource TextC}"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Outline}"
                BorderThickness="0,0,0,1" Padding="14,9">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="13" Height="13" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="MODEL CODEX" Style="{StaticResource Display}" FontSize="19"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GameDirText}" Foreground="{StaticResource TextFaint}"
                               FontSize="11" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Export  ▾" Click="OnExportMenu" IsEnabled="{Binding IndexLoaded}" Margin="0,0,8,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Export this package (bulk)" Command="{Binding ExportPackageCommand}"/>
                                <Separator/>
                                <MenuItem Header="Open export folder" Command="{Binding OpenExportFolderCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="Settings" Click="OnSettings"/>
                    <Button Content="Load models" Style="{StaticResource Primary}" Margin="8,0,0,0"
                            Command="{Binding LoadIndexCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <Border Grid.Row="1" Background="{StaticResource Inset2}" Padding="14,6"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Height="6" Minimum="0" Maximum="1" Value="{Binding ProgressValue}"
                             Background="{StaticResource Inset3}" Foreground="{StaticResource Accent}"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Foreground="{StaticResource TextDim}"
                           FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0"
                    ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="b" Background="{StaticResource Panel}" Margin="0,0,2,0"
                                        BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,2"
                                        PreviewMouseDown="OnTabPressed">
                                    <StackPanel Orientation="Horizontal" Margin="12,7">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextDim}"
                                                   FontSize="12"/>
                                        <Button x:Name="close" Content="✕" Margin="8,0,0,0" Padding="3,0"
                                                BorderThickness="0" Background="Transparent"
                                                Foreground="{StaticResource TextFaint}" FontSize="11"
                                                Click="OnCloseTab"
                                                Visibility="{Binding CanClose, Converter={StaticResource BoolVis}}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        <Setter TargetName="b" Property="Background" Value="{StaticResource Bg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource Panel}" BorderBrush="{StaticResource Outline}"
                BorderThickness="0,1,0,0" Padding="14,5">
            <StackPanel Orientation="Horizontal">
                <Rectangle Width="7" Height="7" Fill="{StaticResource Accent}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDim}"
                           FontSize="11" Margin="9,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
